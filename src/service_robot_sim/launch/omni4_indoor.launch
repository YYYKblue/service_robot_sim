<launch>
  <!-- Gazebo options -->
  <arg name="world" default="$(find my_world)/worlds/indoor.world" />
  <arg name="paused" default="false" />
  <arg name="use_sim_time" default="true" />
  <arg name="gui" default="true" />
  <arg name="headless" default="false" />
  <arg name="debug" default="false" />

  <!-- Robot spawn pose. (2.0, 8.05) is clear of the nurse-station table. -->
  <arg name="model_name" default="sweeper_robot_omni4_base" />
  <arg name="x" default="2.0" />
  <arg name="y" default="8.05" />
  <arg name="z" default="0.01" />
  <arg name="yaw" default="1.5708" />

  <!-- Optional RViz -->
  <arg name="rviz" default="false" />
  <arg name="view" default="iso" />

  <param name="use_sim_time" value="$(arg use_sim_time)" />

  <!-- Start exactly one Gazebo instance with the supplied indoor world. -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(arg world)" />
    <arg name="paused" value="$(arg paused)" />
    <arg name="use_sim_time" value="$(arg use_sim_time)" />
    <arg name="gui" value="$(arg gui)" />
    <arg name="headless" value="$(arg headless)" />
    <arg name="debug" value="$(arg debug)" />
  </include>

  <!-- Load and publish the robot model. -->
  <param name="robot_description"
         textfile="$(find sweeper_robot_omni4_base_ros)/urdf/sweeper_robot_omni4_base.urdf" />

  <node pkg="robot_state_publisher"
        type="robot_state_publisher"
        name="robot_state_publisher"
        output="screen" />

  <!-- Converts /cmd_vel into wheel joint-state visualization data.
       Actual base movement is produced by libgazebo_ros_planar_move.so in the URDF. -->
  <node pkg="sweeper_robot_omni4_base_ros"
        type="velocity_interface_node.py"
        name="sweeper_omni4_velocity_interface"
        output="screen" />

  <!-- Insert the robot into the already running indoor world. -->
  <node pkg="gazebo_ros"
        type="spawn_model"
        name="spawn_sweeper_robot"
        output="screen"
        args="-urdf -param robot_description -model $(arg model_name) -x $(arg x) -y $(arg y) -z $(arg z) -Y $(arg yaw)" />

  <node if="$(arg rviz)"
        pkg="rviz"
        type="rviz"
        name="rviz"
        args="-d $(find sweeper_robot_omni4_base_ros)/rviz/$(arg view).rviz" />
</launch>
