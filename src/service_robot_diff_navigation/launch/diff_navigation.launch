<launch>
  <arg name="gui" default="true" />
  <arg name="rviz" default="true" />
  <arg name="map_file" default="$(find service_robot_diff_navigation)/maps/indoor.yaml" />
  <arg name="x" default="2.0" />
  <arg name="y" default="8.05" />
  <arg name="yaw" default="1.5708" />

  <include file="$(find service_robot_diff_navigation)/launch/diff_sim.launch">
    <arg name="gui" value="$(arg gui)" />
    <arg name="x" value="$(arg x)" />
    <arg name="y" value="$(arg y)" />
    <arg name="yaw" value="$(arg yaw)" />
  </include>

  <include file="$(find service_robot_diff_navigation)/launch/navigation.launch">
    <arg name="map_file" value="$(arg map_file)" />
    <arg name="rviz" value="$(arg rviz)" />
  </include>
</launch>
