<launch>
  <arg name="rviz" default="true" />

  <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping" output="screen">
    <remap from="scan" to="/scan" />
    <rosparam command="load" file="$(find service_robot_navigation)/config/gmapping_params.yaml" />
  </node>

  <node if="$(arg rviz)" pkg="rviz" type="rviz" name="rviz_mapping"
        args="-d $(find service_robot_navigation)/rviz/navigation.rviz" />
</launch>
