  </link>
  <link name="front_left_omni_wheel_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.25000" />
      <inertia ixx="0.00021500" ixy="0" ixz="0" iyy="0.00031300" iyz="0" izz="0.00021500" />
    </inertial>
    <visual name="front_left_high_resolution_omni_wheel_metal">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sweeper_robot_omni4_base_ros/meshes/omni_wheel_metal.stl" />
      </geometry>
      <material name="wheel_silver" />
    </visual>
    <visual name="front_left_high_resolution_omni_wheel_rollers">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sweeper_robot_omni4_base_ros/meshes/omni_wheel_rollers.stl" />
      </geometry>
      <material name="roller_light" />
    </visual>
    <collision name="front_left_wheel_collision">
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.0500" length="0.0530" />
      </geometry>
    </collision>
  </link>
  <joint name="front_left_omni_wheel_joint" type="continuous">
    <parent link="base_link" />
    <child link="front_left_omni_wheel_link" />
    <origin xyz="0.1450 0.1450 0.0550" rpy="0 0 -0.7854" />
    <axis xyz="0 1 0" />
  </joint>
  <link name="front_right_omni_wheel_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.25000" />
      <inertia ixx="0.00021500" ixy="0" ixz="0" iyy="0.00031300" iyz="0" izz="0.00021500" />
    </inertial>
    <visual name="front_right_high_resolution_omni_wheel_metal">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sweeper_robot_omni4_base_ros/meshes/omni_wheel_metal.stl" />
      </geometry>
      <material name="wheel_silver" />
    </visual>
    <visual name="front_right_high_resolution_omni_wheel_rollers">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sweeper_robot_omni4_base_ros/meshes/omni_wheel_rollers.stl" />
      </geometry>
      <material name="roller_light" />
    </visual>
    <collision name="front_right_wheel_collision">
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.0500" length="0.0530" />
      </geometry>
    </collision>
  </link>
  <joint name="front_right_omni_wheel_joint" type="continuous">
    <parent link="base_link" />
    <child link="front_right_omni_wheel_link" />
    <origin xyz="0.1450 -0.1450 0.0550" rpy="0 0 -2.3562" />
    <axis xyz="0 1 0" />
  </joint>
  <link name="rear_left_omni_wheel_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.25000" />
      <inertia ixx="0.00021500" ixy="0" ixz="0" iyy="0.00031300" iyz="0" izz="0.00021500" />
    </inertial>
    <visual name="rear_left_high_resolution_omni_wheel_metal">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sweeper_robot_omni4_base_ros/meshes/omni_wheel_metal.stl" />
      </geometry>
      <material name="wheel_silver" />
    </visual>
    <visual name="rear_left_high_resolution_omni_wheel_rollers">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sweeper_robot_omni4_base_ros/meshes/omni_wheel_rollers.stl" />
      </geometry>
      <material name="roller_light" />
    </visual>
    <collision name="rear_left_wheel_collision">
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.0500" length="0.0530" />
      </geometry>
    </collision>
  </link>
  <joint name="rear_left_omni_wheel_joint" type="continuous">
    <parent link="base_link" />
    <child link="rear_left_omni_wheel_link" />
    <origin xyz="-0.1450 0.1450 0.0550" rpy="0 0 0.7854" />
    <axis xyz="0 1 0" />
  </joint>
  <link name="rear_right_omni_wheel_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.25000" />
      <inertia ixx="0.00021500" ixy="0" ixz="0" iyy="0.00031300" iyz="0" izz="0.00021500" />
    </inertial>
    <visual name="rear_right_high_resolution_omni_wheel_metal">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sweeper_robot_omni4_base_ros/meshes/omni_wheel_metal.stl" />
      </geometry>
      <material name="wheel_silver" />
    </visual>
    <visual name="rear_right_high_resolution_omni_wheel_rollers">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sweeper_robot_omni4_base_ros/meshes/omni_wheel_rollers.stl" />
      </geometry>
      <material name="roller_light" />
    </visual>
    <collision name="rear_right_wheel_collision">
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.0500" length="0.0530" />
      </geometry>
    </collision>
  </link>
  <joint name="rear_right_omni_wheel_joint" type="continuous">
    <parent link="base_link" />
    <child link="rear_right_omni_wheel_link" />
    <origin xyz="-0.1450 -0.1450 0.0550" rpy="0 0 -3.9270" />
    <axis xyz="0 1 0" />
  </joint>
  <link name="lidar_link">
    <inertial>
      <origin xyz="0 0 0.032" rpy="0 0 0" />
      <mass value="0.18000" />
      <inertia ixx="0.00008000" ixy="0" ixz="0" iyy="0.00008000" iyz="0" izz="0.00010000" />
    </inertial>
    <visual name="lidar_blue_body">
      <origin xyz="0 0 0.0275" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0400" length="0.0550" />
      </geometry>
      <material name="lidar_blue" />
    </visual>
    <visual name="lidar_dark_cap">
      <origin xyz="0 0 0.0590" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0410" length="0.0080" />
      </geometry>
      <material name="sensor_dark" />
    </visual>
    <collision name="lidar_collision">
      <origin xyz="0 0 0.032" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.0410" length="0.0630" />
      </geometry>
    </collision>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link" />
    <child link="lidar_link" />
    <origin xyz="0 0 0.1610" rpy="0 0 0" />
  </joint>
  <gazebo>
    <plugin name="omni_drive_controller" filename="libgazebo_ros_planar_move.so">
      <robotNamespace>/</robotNamespace>
      <commandTopic>cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic>
      <odometryFrame>odom</odometryFrame>
      <robotBaseFrame>base_footprint</robotBaseFrame>
      <publishOdomTF>true</publishOdomTF>
      <publishWheelTF>false</publishWheelTF>
      <odometryRate>50.0</odometryRate>
      <updateRate>50.0</updateRate>
      <!-- Stop the base if /cmd_vel is not refreshed within this interval. -->
      <cmdTimeout>0.2</cmdTimeout>
    </plugin>
  </gazebo>
  <gazebo reference="lidar_link">
    <sensor type="ray" name="lidar_2d_sensor">
      <pose>0 0 0.035 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.1415926</min_angle>
            <max_angle>3.1415926</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.08</min>
          <max>8.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="gazebo_ros_laser_controller" filename="libgazebo_ros_laser.so">
        <topicName>/scan</topicName>
        <frameName>lidar_link</frameName>
      </plugin>
    </sensor>
  </gazebo>
  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="lidar_link">
    <material>Gazebo/Blue</material>
  </gazebo>
  <gazebo reference="front_left_omni_wheel_link">
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
    <kp>100000.0</kp>
    <kd>1.0</kd>
  </gazebo>
  <gazebo reference="front_right_omni_wheel_link">
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
    <kp>100000.0</kp>
    <kd>1.0</kd>
  </gazebo>
  <gazebo reference="rear_left_omni_wheel_link">
    <mu1>0.8</mu1>
