    <kp>100000.0</kp>
    <kd>1.0</kd>
  </gazebo>
  <gazebo reference="rear_right_omni_wheel_link">
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
    <kp>100000.0</kp>
    <kd>1.0</kd>
  </gazebo>
</robot>
