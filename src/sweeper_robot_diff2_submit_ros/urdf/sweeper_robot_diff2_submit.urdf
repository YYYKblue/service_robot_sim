<?xml version="1.0"?>
<robot name="sweeper_robot_diff2_submit">
  <!-- The outer body intentionally follows sweeper_robot_omni4_base_ros. -->
  <material name="chassis_dark"><color rgba="0.10 0.13 0.13 1.0"/></material>
  <material name="chassis_top"><color rgba="0.23 0.26 0.27 1.0"/></material>
  <material name="mount_dark"><color rgba="0.02 0.025 0.028 1.0"/></material>
  <material name="axle_silver"><color rgba="0.72 0.72 0.68 1.0"/></material>
  <material name="rubber_black"><color rgba="0.005 0.005 0.006 1.0"/></material>
  <material name="rubber_edge"><color rgba="0.035 0.035 0.038 1.0"/></material>
  <material name="hub_silver"><color rgba="0.78 0.78 0.74 1.0"/></material>
  <material name="axle_dark"><color rgba="0.045 0.050 0.055 1.0"/></material>
  <material name="lidar_blue"><color rgba="0.0 0.42 0.68 1.0"/></material>
  <material name="orange_marker"><color rgba="1.0 0.5 0.0 1.0"/></material>
  <material name="sensor_dark"><color rgba="0.02 0.025 0.03 1.0"/></material>

  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Canonical omni chassis shell, collision envelope and front marker. -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <mass value="4.00000"/>
      <inertia ixx="0.06370000" ixy="0" ixz="0" iyy="0.06370000" iyz="0" izz="0.12500000"/>
    </inertial>
    <visual name="single_round_0p5m_chassis">
      <origin xyz="0 0 0.1250" rpy="0 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.0600"/></geometry>
      <material name="chassis_dark"/>
    </visual>
    <visual name="slightly_raised_top_plate">
      <origin xyz="0 0 0.1570" rpy="0 0 0"/>
      <geometry><cylinder radius="0.2350" length="0.0060"/></geometry>
      <material name="chassis_top"/>
    </visual>
    <visual name="lower_diagonal_support_beam_a">
      <origin xyz="0 0 0.0790" rpy="0 0 0.7854"/>
      <geometry><box size="0.335 0.032 0.026"/></geometry>
      <material name="mount_dark"/>
    </visual>
    <visual name="lower_diagonal_support_beam_b">
      <origin xyz="0 0 0.0790" rpy="0 0 -0.7854"/>
      <geometry><box size="0.335 0.032 0.026"/></geometry>
      <material name="mount_dark"/>
    </visual>
    <visual name="lower_center_axle_hub">
      <origin xyz="0 0 0.0790" rpy="0 0 0"/>
      <geometry><cylinder radius="0.0480" length="0.0300"/></geometry>
      <material name="mount_dark"/>
    </visual>
    <visual name="front_left_inner_axle_bracket">
      <origin xyz="0.0955 0.0955 0.0810" rpy="0 0 -0.7854"/>
      <geometry><box size="0.052 0.034 0.060"/></geometry>
      <material name="mount_dark"/>
    </visual>
    <visual name="front_left_through_axle">
      <origin xyz="0.1199 0.1199 0.0550" rpy="0 1.5708 0.7854"/>
      <geometry><cylinder radius="0.0080" length="0.0750"/></geometry>
      <material name="axle_silver"/>
    </visual>
    <visual name="front_left_inner_bearing_socket">
      <origin xyz="0.1177 0.1177 0.0550" rpy="0 1.5708 0.7854"/>
      <geometry><cylinder radius="0.0200" length="0.0260"/></geometry>
      <material name="axle_silver"/>
    </visual>
    <visual name="front_right_inner_axle_bracket">
      <origin xyz="0.0955 -0.0955 0.0810" rpy="0 0 -2.3562"/>
      <geometry><box size="0.052 0.034 0.060"/></geometry>
      <material name="mount_dark"/>
    </visual>
    <visual name="front_right_through_axle">
      <origin xyz="0.1199 -0.1199 0.0550" rpy="0 1.5708 -0.7854"/>
      <geometry><cylinder radius="0.0080" length="0.0750"/></geometry>
      <material name="axle_silver"/>
    </visual>
    <visual name="front_right_inner_bearing_socket">
      <origin xyz="0.1177 -0.1177 0.0550" rpy="0 1.5708 -0.7854"/>
      <geometry><cylinder radius="0.0200" length="0.0260"/></geometry>
      <material name="axle_silver"/>
    </visual>
    <visual name="rear_left_inner_axle_bracket">
      <origin xyz="-0.0955 0.0955 0.0810" rpy="0 0 0.7854"/>
      <geometry><box size="0.052 0.034 0.060"/></geometry>
      <material name="mount_dark"/>
    </visual>
    <visual name="rear_left_through_axle">
      <origin xyz="-0.1199 0.1199 0.0550" rpy="0 1.5708 2.3562"/>
      <geometry><cylinder radius="0.0080" length="0.0750"/></geometry>
      <material name="axle_silver"/>
    </visual>
    <visual name="rear_left_inner_bearing_socket">
      <origin xyz="-0.1177 0.1177 0.0550" rpy="0 1.5708 2.3562"/>
      <geometry><cylinder radius="0.0200" length="0.0260"/></geometry>
      <material name="axle_silver"/>
    </visual>
    <visual name="rear_right_inner_axle_bracket">
      <origin xyz="-0.0955 -0.0955 0.0810" rpy="0 0 -3.9270"/>
      <geometry><box size="0.052 0.034 0.060"/></geometry>
      <material name="mount_dark"/>
    </visual>
    <visual name="rear_right_through_axle">
      <origin xyz="-0.1199 -0.1199 0.0550" rpy="0 1.5708 -2.3562"/>
      <geometry><cylinder radius="0.0080" length="0.0750"/></geometry>
      <material name="axle_silver"/>
    </visual>
    <visual name="rear_right_inner_bearing_socket">
      <origin xyz="-0.1177 -0.1177 0.0550" rpy="0 1.5708 -2.3562"/>
      <geometry><cylinder radius="0.0200" length="0.0260"/></geometry>
      <material name="axle_silver"/>
    </visual>
    <collision name="chassis_collision">
      <origin xyz="0 0 0.1250" rpy="0 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.0600"/></geometry>
    </collision>
    <visual name="front_x_arrow_marker">
      <origin xyz="0.225 0 0.176" rpy="0 0 0"/>
      <geometry><box size="0.120 0.045 0.018"/></geometry>
      <material name="orange_marker"/>
    </visual>
    <visual name="front_x_arrow_tip_marker">
      <origin xyz="0.292 0 0.176" rpy="0 0 0.7854"/>
      <geometry><box size="0.052 0.052 0.018"/></geometry>
      <material name="orange_marker"/>
    </visual>
  </link>

  <!-- The wheel geometry remains differential, but uses the common +X frame. -->
  <link name="left_drive_wheel_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.3600"/>
      <inertia ixx="0.00045000" ixy="0" ixz="0" iyy="0.00029000" iyz="0" izz="0.00045000"/>
    </inertial>
    <visual name="left_rubber_tire">
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0680" length="0.0460"/></geometry>
      <material name="rubber_black"/>
    </visual>
    <visual name="left_outer_sidewall">
      <origin xyz="0 0.0240 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0640" length="0.0040"/></geometry>
      <material name="rubber_edge"/>
    </visual>
    <visual name="left_inner_sidewall">
      <origin xyz="0 -0.0230 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0640" length="0.0040"/></geometry>
      <material name="rubber_edge"/>
    </visual>
    <visual name="left_outer_metal_hub">
      <origin xyz="0 0.0270 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0400" length="0.0080"/></geometry>
      <material name="hub_silver"/>
    </visual>
    <visual name="left_inner_metal_hub">
      <origin xyz="0 -0.0260 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0320" length="0.0060"/></geometry>
      <material name="hub_silver"/>
    </visual>
    <visual name="left_center_bearing">
      <origin xyz="0 0.0330 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0180" length="0.0050"/></geometry>
      <material name="axle_dark"/>
    </visual>
    <visual name="left_bearing_hole">
      <origin xyz="0 0.0370 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0080" length="0.0030"/></geometry>
      <material name="sensor_dark"/>
    </visual>
    <visual name="left_inner_mount_hub">
      <origin xyz="0 -0.0260 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0280" length="0.0080"/></geometry>
      <material name="axle_dark"/>
    </visual>
    <collision name="left_wheel_collision">
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0680" length="0.0460"/></geometry>
    </collision>
  </link>
  <joint name="left_drive_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_drive_wheel_link"/>
    <origin xyz="0 0.1980 0.0680" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="right_drive_wheel_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.3600"/>
      <inertia ixx="0.00045000" ixy="0" ixz="0" iyy="0.00029000" iyz="0" izz="0.00045000"/>
    </inertial>
    <visual name="right_rubber_tire">
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0680" length="0.0460"/></geometry>
      <material name="rubber_black"/>
    </visual>
    <visual name="right_outer_sidewall">
      <origin xyz="0 -0.0240 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0640" length="0.0040"/></geometry>
      <material name="rubber_edge"/>
    </visual>
    <visual name="right_inner_sidewall">
      <origin xyz="0 0.0230 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0640" length="0.0040"/></geometry>
      <material name="rubber_edge"/>
    </visual>
    <visual name="right_outer_metal_hub">
      <origin xyz="0 -0.0270 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0400" length="0.0080"/></geometry>
      <material name="hub_silver"/>
    </visual>
    <visual name="right_inner_metal_hub">
      <origin xyz="0 0.0260 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0320" length="0.0060"/></geometry>
      <material name="hub_silver"/>
    </visual>
    <visual name="right_center_bearing">
      <origin xyz="0 -0.0330 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0180" length="0.0050"/></geometry>
      <material name="axle_dark"/>
    </visual>
    <visual name="right_bearing_hole">
      <origin xyz="0 -0.0370 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0080" length="0.0030"/></geometry>
      <material name="sensor_dark"/>
    </visual>
    <visual name="right_inner_mount_hub">
      <origin xyz="0 0.0260 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0280" length="0.0080"/></geometry>
      <material name="axle_dark"/>
    </visual>
    <collision name="right_wheel_collision">
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0680" length="0.0460"/></geometry>
    </collision>
  </link>
  <joint name="right_drive_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_drive_wheel_link"/>
    <origin xyz="0 -0.1980 0.0680" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="lidar_link">
    <inertial>
      <origin xyz="0 0 0.032" rpy="0 0 0"/>
      <mass value="0.18000"/>
      <inertia ixx="0.00008000" ixy="0" ixz="0" iyy="0.00008000" iyz="0" izz="0.00010000"/>
    </inertial>
    <visual name="lidar_blue_body">
      <origin xyz="0 0 0.0275" rpy="0 0 0"/>
      <geometry><cylinder radius="0.0400" length="0.0550"/></geometry>
      <material name="lidar_blue"/>
    </visual>
    <visual name="lidar_dark_cap">
      <origin xyz="0 0 0.0590" rpy="0 0 0"/>
      <geometry><cylinder radius="0.0410" length="0.0080"/></geometry>
      <material name="sensor_dark"/>
    </visual>
    <collision name="lidar_collision">
      <origin xyz="0 0 0.032" rpy="0 0 0"/>
      <geometry><cylinder radius="0.0410" length="0.0630"/></geometry>
    </collision>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.1610" rpy="0 0 0"/>
  </joint>

  <gazebo>
    <plugin name="diff_drive_controller" filename="libgazebo_ros_diff_drive.so">
      <robotNamespace>/</robotNamespace>
      <commandTopic>cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic>
      <odometryFrame>odom</odometryFrame>
      <robotBaseFrame>base_footprint</robotBaseFrame>
      <leftJoint>left_drive_wheel_joint</leftJoint>
      <rightJoint>right_drive_wheel_joint</rightJoint>
      <wheelSeparation>0.3960</wheelSeparation>
      <wheelDiameter>0.1360</wheelDiameter>
      <publishWheelTF>false</publishWheelTF>
      <publishOdomTF>true</publishOdomTF>
      <publishWheelJointState>true</publishWheelJointState>
      <updateRate>50.0</updateRate>
      <cmdTimeout>0.2</cmdTimeout>
    </plugin>
  </gazebo>
  <gazebo reference="lidar_link">
    <sensor type="ray" name="lidar_2d_sensor">
      <pose>0 0 0.035 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.1415926</min_angle>
            <max_angle>3.1415926</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.08</min>
          <max>8.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="gazebo_ros_laser_controller" filename="libgazebo_ros_laser.so">
        <topicName>/scan</topicName>
        <frameName>lidar_link</frameName>
      </plugin>
    </sensor>
  </gazebo>
  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="lidar_link">
    <material>Gazebo/Blue</material>
  </gazebo>
  <gazebo reference="left_drive_wheel_link">
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
    <kp>100000.0</kp>
    <kd>1.0</kd>
  </gazebo>
  <gazebo reference="right_drive_wheel_link">
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
    <kp>100000.0</kp>
    <kd>1.0</kd>
  </gazebo>
</robot>
